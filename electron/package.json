{
  "name": "dark-hollow",
  "version": "1.0.0",
  "description": "Dark Hollow - A 2D Platformer Hack and Slash",
  "main": "main.js",
  "author": "Dark Hollow Studio",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "build:frontend": "cd ../frontend && yarn build",
    "build:win": "npm run build:frontend && electron-builder --win",
    "build:mac": "npm run build:frontend && electron-builder --mac",
    "build:linux": "npm run build:frontend && electron-builder --linux",
    "build:all": "npm run build:frontend && electron-builder --win --mac --linux",
    "dev": "cd ../frontend && yarn build && cd ../electron && electron ."
  },
  "build": {
    "appId": "com.darkhollow.game",
    "productName": "Dark Hollow",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "icon.png"
    ],
    "extraResources": [
      {
        "from": "../frontend/build",
        "to": "app/frontend/build",
        "filter": ["**/*"]
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        },
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ],
      "icon": "icon.png"
    },
    "mac": {
      "target": ["dmg"],
      "icon": "icon.png",
      "category": "public.app-category.games"
    },
    "linux": {
      "target": ["AppImage"],
      "icon": "icon.png",
      "category": "Game"
    },
    "nsis": {
      "oneClick": true,
      "allowToChangeInstallationDirectory": false,
      "installerIcon": "icon.png",
      "uninstallerIcon": "icon.png",
      "deleteAppDataOnUninstall": true
    },
    "portable": {
      "artifactName": "DarkHollow-Portable-${version}.${ext}"
    }
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8"
  }
}
